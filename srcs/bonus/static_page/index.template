<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Inception - Welcome</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg:       #f7f5f0;
      --ink:      #1a1916;
      --muted:    #7a7670;
      --border:   #d9d6cf;
      --accent:   #2e6a4e;
      --hover-bg: #edeae3;
    }

    html, body {
      height: 100%;
    }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'DM Mono', monospace;
      font-weight: 300;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 2rem;
    }

    .container {
      width: 100%;
      max-width: 520px;
    }

    /* ── Header ── */
    header {
      margin-bottom: 3rem;
    }

    .eyebrow {
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }

    h1 {
      font-family: 'DM Serif Display', serif;
      font-weight: 400;
      font-size: clamp(2rem, 6vw, 2.8rem);
      line-height: 1.1;
      letter-spacing: -0.01em;
    }

    h1 em {
      font-style: italic;
      color: var(--accent);
    }

    .subtitle {
      margin-top: 1rem;
      font-size: 0.8rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── Divider ── */
    .divider {
      height: 1px;
      background: var(--border);
      margin: 2rem 0;
    }

    /* ── Links ── */
    .links-label {
      font-size: 0.65rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }

    .links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .links li a {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.9rem 1rem;
      border: 1px solid var(--border);
      border-radius: 4px;
      text-decoration: none;
      color: var(--ink);
      font-size: 0.8rem;
      transition: background 0.15s ease, border-color 0.15s ease;
    }

    .links li a:hover {
      background: var(--hover-bg);
      border-color: #b8b4ac;
    }

    .link-path {
      font-weight: 400;
    }

    .link-desc {
      font-size: 0.7rem;
      color: var(--muted);
    }

    .link-arrow {
      font-size: 0.75rem;
      color: var(--muted);
      transition: transform 0.15s ease, color 0.15s ease;
    }

    .links li a:hover .link-arrow {
      transform: translateX(3px);
      color: var(--accent);
    }

    /* ── Domain badge ── */
    .domain-badge {
      margin-top: 2.5rem;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.7rem;
      color: var(--muted);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 0.35rem 0.75rem;
    }

    .domain-badge span {
      color: var(--accent);
      font-weight: 400;
    }

    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      opacity: 0.7;
    }
  </style>
</head>
<body>
  <div class="container">

    <header>
      <h1>Welcome to<br /><em>Inception</em></h1>
      <p class="subtitle">
        Select a service below to get started
      </p>
    </header>

    <div class="divider"></div>

    <p class="links-label">Available Services</p>
    <ul class="links">

      <li>
        <a href="https://${DOMAIN_NAME}">
          <span>
            <span class="link-path">/wordpress</span><br />
            <span class="link-desc">WordPress website</span>
          </span>
          <span class="link-arrow">→</span>
        </a>
      </li>

      <li>
        <a href="https://${DOMAIN_NAME}/adminer">
          <span>
            <span class="link-path">/adminer</span><br />
            <span class="link-desc">Database Manager</span>
          </span>
          <span class="link-arrow">→</span>
        </a>
      </li>

      <li>
        <a href="https://${DOMAIN_NAME}/glance">
          <span>
            <span class="link-path">/glance</span><br />
            <span class="link-desc">Dashboard system</span>
          </span>
          <span class="link-arrow">→</span>
        </a>
      </li>

      <li>
        <a href="https://${DOMAIN_NAME}/welcome">
          <span>
            <span class="link-path">/welcome</span><br />
            <span class="link-desc">Current Page</span>
          </span>
          <span class="link-arrow">→</span>
        </a>
      </li>

    </ul>

    <div class="domain-badge">
      <div class="dot"></div>
      Hosted on <span>${DOMAIN_NAME}</span>
    </div>

  </div>
</body>
</html>